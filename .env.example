# Auth (session cookie — see server/auth.ts)
SESSION_SECRET=change_me_strong_session_secret
# Optional. Omit for "auto": Secure cookies on HTTPS (needs X-Forwarded-Proto when behind a proxy).
# SESSION_COOKIE_SECURE=true
# SESSION_COOKIE_SAME_SITE=lax
# Only if all app URLs share one parent domain (wrong value = no cookies): SESSION_COOKIE_DOMAIN=.yourdomain.com
# If nginx sends X-Forwarded-Proto correctly, set this to opt out of the default inferred https in production:
# STRICT_X_FORWARDED_PROTO=1

# Storage
OBJECT_STORAGE_PROVIDER=local
LOCAL_STORAGE_DIR=./storage
PRIVATE_OBJECT_DIR=private

# Database (any Postgres, including hosted providers)
DATABASE_URL=postgresql://user:password@host:5432/easyfuel

# OZOW – pay-ins (One API only)
OZOW_IS_TEST=false
OZOW_SITE_CODE=your-site-code
OZOW_CLIENT_ID=your-client-id
OZOW_CLIENT_SECRET=your-client-secret
# Staging: https://stagingone.ozow.com | Production: https://one.ozow.com
OZOW_ONE_API_BASE_URL=https://stagingone.ozow.com

# OZOW – payouts (from Ozow staging/production merchant dashboard)
# OZOW_PAYOUT_API_BASE_URL=https://stagingpayoutsapi.ozow.com
# OZOW_PAYOUT_SUBMIT_PATH=/v1/requestpayout
# Payout API Key from Merchant Details (NOT One API Client Secret)
OZOW_PAYOUT_API_KEY=your-payout-api-key
# OZOW_PAYOUT_ACCESS_TOKEN=your-24-char-token
# OZOW_PAYOUT_DRY_RUN=true
# OZOW_PAYOUT_NOTIFICATION_URL=https://your-domain.com/api/webhooks/ozow-payout-notification
# OZOW_PAYOUT_VERIFICATION_URL=https://your-domain.com/api/webhooks/ozow-payout-verification

# Staging only: skip webhook hash verify while aligning with Ozow docs (requires OZOW_IS_TEST=true)
# OZOW_WEBHOOK_SKIP_VERIFY=true
# Staging only: skip live Ozow checkout and auto-mark payment complete (requires OZOW_IS_TEST=true)
# OZOW_PAYIN_DRY_RUN=true

# Hours after delivery before unpaid payment reminder (default 24)
# PAYMENT_REMINDER_AFTER_HOURS=24

# Base URL of your app (success/cancel redirects + webhook URLs; HTTPS in production)
PUBLIC_APP_URL=https://your-domain.com
# When true, subscription checkout activates immediately without Ozow (dev only)
SUBSCRIPTION_TEST_MODE=false

# Transactional email (Resend — https://resend.com)
# Required for driver/customer order emails. If unset, sends are skipped (logged).
RESEND_API_KEY=
# Must be a verified sender/domain in Resend, e.g. Easy Fuel <orders@yourdomain.com>
RESEND_FROM_EMAIL=Easy Fuel ZA <noreply@easyfuel.ai>
# Optional: comma- or semicolon-separated addresses that receive admin compliance alerts
# (KYC/KYB, document review, new vehicles). If unset, all users with role=admin and a local_auth_users email are used.
# ADMIN_COMPLIANCE_EMAILS=compliance@yourdomain.com,ops@yourdomain.com

# Maps
VITE_MAPBOX_TOKEN=your-mapbox-token
# Optional web websocket override (otherwise defaults to same-origin `/ws`)
# VITE_WS_URL=ws://localhost:5002/ws

# Push Notifications
# Web push (browser)
VAPID_PUBLIC_KEY=BHJi0aouceDkxzSsR066Bg-MF1aeGQAMzR9u2V68h5N1sy4H7xA3TG6kH0kVBth8rkgQdxbXP5hCXiFGnGrnDnU
VAPID_PRIVATE_KEY=PWsA6LYFb7Qy6iJEFQMr0shylVosWdR4NRgksDId7Nk
# Expo push (mobile)
# No server secret is required for basic Expo push API usage.
# Ensure your mobile app uses an EAS project ID for production push delivery.

# Auth (session cookie — see server/auth.ts)
SESSION_SECRET=change_me_strong_session_secret
# Optional. Omit for "auto": Secure cookies on HTTPS (needs X-Forwarded-Proto when behind a proxy).
# SESSION_COOKIE_SECURE=true
# SESSION_COOKIE_SAME_SITE=lax
# Only if all app URLs share one parent domain (wrong value = no cookies): SESSION_COOKIE_DOMAIN=.yourdomain.com

# Storage
OBJECT_STORAGE_PROVIDER=local
LOCAL_STORAGE_DIR=./storage
PRIVATE_OBJECT_DIR=private

# Database (any Postgres, including hosted providers)
DATABASE_URL=postgresql://user:password@host:5432/easyfuel

# PayFast (South Africa Payment Gateway)
PF_MODE=sandbox
PF_MERCHANT_ID=your-merchant-id
PF_MERCHANT_KEY=your-merchant-key
PF_PASSPHRASE=your-passphrase
PF_RETURN_URL=https://your-domain/api/payments/return
PF_CANCEL_URL=https://your-domain/api/payments/cancel
PF_NOTIFY_URL=https://your-domain/api/payments/itn

# OZOW (Driver subscription payments – Pay by Bank)
OZOW_SITE_CODE=your-site-code
OZOW_PRIVATE_KEY=your-private-key
OZOW_API_KEY=your-api-key
OZOW_BASE_URL=https://pay.ozow.com
OZOW_IS_TEST=false
# When true, driver subscription "Subscribe" activates the plan immediately without OZOW checkout (for testing).
SUBSCRIPTION_TEST_MODE=false
# Base URL of your app (used for success/cancel and webhook URLs; must be HTTPS in production)
PUBLIC_APP_URL=https://your-domain.com

# Maps
VITE_MAPBOX_TOKEN=your-mapbox-token

# Push Notifications
# Web push (browser)
VAPID_PUBLIC_KEY=BHJi0aouceDkxzSsR066Bg-MF1aeGQAMzR9u2V68h5N1sy4H7xA3TG6kH0kVBth8rkgQdxbXP5hCXiFGnGrnDnU
VAPID_PRIVATE_KEY=PWsA6LYFb7Qy6iJEFQMr0shylVosWdR4NRgksDId7Nk

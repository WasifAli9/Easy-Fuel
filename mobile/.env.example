# API origin only (no trailing /api). Matches Inspect360-style EXPO_PUBLIC_API_URL.
# EXPO_PUBLIC_API_URL=https://portal.easyfuel.ai
EXPO_PUBLIC_API_BASE_URL=https://portal.easyfuel.ai

# Optional override; if unset, WebSocket URL is derived from the resolved API base (same host, path /ws).
# EXPO_PUBLIC_WS_URL=wss://portal.easyfuel.ai/ws

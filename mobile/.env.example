# EXPO_PUBLIC_WS_URL=ws://192.168.1.10:5002/ws
# Required for production Expo push notifications (background/terminated app behavior).
# Set this from your EAS project configuration.
# EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id
# Set auth provider on server to local for full Supabase exit.
# Mobile no longer requires Supabase credentials in local-auth mode.
EXPO_PUBLIC_SUPABASE_URL=https://piejkqvpkxnrnudztrmt.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
